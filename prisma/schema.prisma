generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id                     String   @id @default(cuid())
  firstName              String
  lastName               String
  dateOfBirth            String
  phone                  String
  email                  String
  preferredContactMethod String   @default("email")
  lastCleaningDate       String?
  recallDueDate          String?
  insuranceProvider      String?
  memberId               String?
  outstandingBalance     Float    @default(0)
  providerId             String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  appointments    Appointment[]
  clinicalNotes   ClinicalNote[]
  insurancePlans  InsurancePlan[]
  insuranceClaims InsuranceClaim[]
  balances        Balance[]
  recallTasks     RecallTask[]
  treatmentPlans  TreatmentPlan[]
  paymentPlans    PaymentPlan[]
  forms           PatientForm[]
  referrals       Referral[]
  communications  Communication[]
  followUps       FollowUp[]
  perioExams      PerioExam[]
  preAuths        PreAuthorization[]
  provider        Provider?         @relation(fields: [providerId], references: [id])
}

model Provider {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  title     String
  specialty String
  createdAt DateTime @default(now())

  patients       Patient[]
  appointments   Appointment[]
  clinicalNotes  ClinicalNote[]
  treatmentPlans TreatmentPlan[] @relation("TreatmentPlanProvider")
  referrals      Referral[]      @relation("ReferralProvider")
  perioExams     PerioExam[]     @relation("PerioExamProvider")
}

model Appointment {
  id         String   @id @default(cuid())
  patientId  String
  providerId String
  date       String
  time       String
  duration   Int
  type       String
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  patient       Patient          @relation(fields: [patientId], references: [id])
  provider      Provider         @relation(fields: [providerId], references: [id])
  clinicalNotes ClinicalNote[]
  claims        InsuranceClaim[]
  followUps     FollowUp[]
}

model ClinicalNote {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String
  providerId    String
  date          String
  transcript    String?
  subjective    String
  objective     String
  assessment    String
  plan          String
  status        String   @default("draft")
  procedureCode String?
  toothNumbers  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient     @relation(fields: [patientId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  provider    Provider    @relation(fields: [providerId], references: [id])
}

model InsurancePlan {
  id                 String   @id @default(cuid())
  patientId          String
  provider           String
  memberId           String
  groupNumber        String
  deductible         Float
  deductibleMet      Float    @default(0)
  annualMax          Float
  annualUsed         Float    @default(0)
  verificationStatus String   @default("pending")
  verifiedDate       String?
  coPayPreventive    Float    @default(0)
  coPayBasic         Float    @default(20)
  coPayMajor         Float    @default(50)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient  Patient            @relation(fields: [patientId], references: [id])
  claims   InsuranceClaim[]
  preAuths PreAuthorization[]
}

model InsuranceClaim {
  id              String   @id @default(cuid())
  patientId       String
  insurancePlanId String
  appointmentId   String
  claimDate       String
  procedureCodes  String
  totalAmount     Float
  narrative       String
  status          String   @default("draft")
  submittedDate   String?
  approvedAmount  Float?
  denialReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  insurancePlan InsurancePlan @relation(fields: [insurancePlanId], references: [id])
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
}

model Balance {
  id                String   @id @default(cuid())
  patientId         String
  amount            Float
  dueDate           String
  lastPaymentDate   String?
  lastPaymentAmount Float?
  statementSent     Boolean  @default(false)
  statementDate     String?
  collectionStatus  String   @default("current")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
}

model RecallTask {
  id               String   @id @default(cuid())
  patientId        String
  lastHygieneDate  String
  recallDueDate    String
  daysOverdue      Int      @default(0)
  contactAttempts  Int      @default(0)
  lastContactDate  String?
  status           String   @default("pending")
  suggestedMessage String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
}

model TreatmentPlan {
  id              String   @id @default(cuid())
  patientId       String
  providerId      String
  title           String
  status          String   @default("proposed") // proposed, accepted, in_progress, completed, declined
  presentedDate   String
  acceptedDate    String?
  totalEstimate   Float
  insuranceEst    Float    @default(0)
  patientEst      Float    @default(0)
  priority        String   @default("standard") // urgent, high, standard, elective
  notes           String?
  sentAt          String?
  planToken       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient  Patient             @relation(fields: [patientId], references: [id])
  provider Provider            @relation("TreatmentPlanProvider", fields: [providerId], references: [id])
  items    TreatmentPlanItem[]
}

model TreatmentPlanItem {
  id              String  @id @default(cuid())
  treatmentPlanId String
  procedureCode   String
  description     String
  toothNumber     String?
  surface         String?
  estimatedCost   Float
  insuranceCoverage Float @default(0)
  patientCost     Float   @default(0)
  status          String  @default("pending") // pending, scheduled, completed
  sequence        Int     @default(1)

  treatmentPlan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id])
}

model PaymentPlan {
  id              String   @id @default(cuid())
  patientId       String
  totalAmount     Float
  downPayment     Float    @default(0)
  remainingAmount Float
  monthlyPayment  Float
  totalInstallments Int
  paidInstallments  Int    @default(0)
  interestRate    Float    @default(0)
  startDate       String
  status          String   @default("active") // active, completed, defaulted, cancelled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient      Patient                  @relation(fields: [patientId], references: [id])
  installments PaymentPlanInstallment[]
}

model PaymentPlanInstallment {
  id            String   @id @default(cuid())
  paymentPlanId String
  installmentNo Int
  amount        Float
  dueDate       String
  paidDate      String?
  status        String   @default("pending") // pending, paid, overdue, missed
  createdAt     DateTime @default(now())

  paymentPlan PaymentPlan @relation(fields: [paymentPlanId], references: [id])
}

model PatientForm {
  id          String   @id @default(cuid())
  patientId   String?
  formType    String   // health_history, consent, financial, hipaa, new_patient
  title       String
  status      String   @default("pending") // pending, submitted, reviewed
  submittedAt String?
  reviewedBy  String?
  reviewedAt  String?
  formData    String?  // JSON string of form field values
  sentAt      String?  // when the form link was texted to the patient
  formToken   String?  // unique token for the patient-facing form link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id])
}

model Referral {
  id              String   @id @default(cuid())
  patientId       String
  referringProvId String
  referredToName  String
  referredToSpecialty String
  referredToPhone String?
  referredToEmail String?
  reason          String
  urgency         String   @default("routine") // urgent, soon, routine
  status          String   @default("pending") // pending, sent, scheduled, completed, declined
  sentDate        String?
  appointmentDate String?
  reportReceived  Boolean  @default(false)
  reportNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id])
  referringProvider Provider @relation("ReferralProvider", fields: [referringProvId], references: [id])
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  category      String   // restorative, preventive, surgical, orthodontic, office, ppe
  sku           String?
  currentStock  Int
  minStock      Int
  maxStock      Int
  unit          String   @default("units") // units, boxes, packs, rolls
  unitCost      Float
  supplier      String?
  lastOrderDate String?
  expiryDate    String?
  location      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Communication {
  id          String   @id @default(cuid())
  patientId   String
  channel     String   // sms, email, phone, portal
  direction   String   // inbound, outbound
  subject     String?
  body        String
  status      String   @default("sent") // draft, sent, delivered, failed, read
  sentAt      String?
  readAt      String?
  sentBy      String   @default("system") // system, provider name
  metadata    String?  // JSON - template used, campaign id, etc
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model FollowUp {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String?
  procedureType String
  procedureDate String
  followUpDate  String
  status        String   @default("pending") // pending, sent, responded, completed
  channel       String   @default("sms") // sms, email, phone
  message       String
  response      String?
  respondedAt   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model PerioExam {
  id          String   @id @default(cuid())
  patientId   String
  providerId  String
  examDate    String
  pocketDepths String  // JSON: {"1":{"B":[3,2,3],"L":[2,2,3]},...} per tooth buccal/lingual
  recession    String? // JSON same format
  bleeding     String? // JSON: {"1":{"B":[0,1,0],"L":[0,0,0]},...} 0/1
  furcation    String? // JSON for furcation involvement
  mobility     String? // JSON: {"14":1,"15":2,...}
  plaque       String? // JSON same format as bleeding
  notes        String?
  createdAt    DateTime @default(now())

  patient  Patient  @relation(fields: [patientId], references: [id])
  provider Provider @relation("PerioExamProvider", fields: [providerId], references: [id])
}

model PreAuthorization {
  id              String   @id @default(cuid())
  patientId       String
  insurancePlanId String
  procedureCodes  String
  toothNumbers    String?
  estimatedCost   Float
  reason          String
  status          String   @default("draft") // draft, submitted, approved, denied, expired
  submittedDate   String?
  responseDate    String?
  approvedAmount  Float?
  denialReason    String?
  expiryDate      String?
  authNumber      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  insurancePlan InsurancePlan @relation(fields: [insurancePlanId], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  description String
  userId      String   @default("demo-user")
  timestamp   DateTime @default(now())
  metadata    String?
}

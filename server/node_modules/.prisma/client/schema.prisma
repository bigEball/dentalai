generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/dentalai.db"
}

model Patient {
  id                     String   @id @default(cuid())
  firstName              String
  lastName               String
  dateOfBirth            String
  phone                  String
  email                  String
  preferredContactMethod String   @default("email")
  lastCleaningDate       String?
  recallDueDate          String?
  insuranceProvider      String?
  memberId               String?
  outstandingBalance     Float    @default(0)
  providerId             String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  appointments    Appointment[]
  clinicalNotes   ClinicalNote[]
  insurancePlans  InsurancePlan[]
  insuranceClaims InsuranceClaim[]
  balances        Balance[]
  recallTasks     RecallTask[]
  radiographs     RadiographStudy[]
  provider        Provider?         @relation(fields: [providerId], references: [id])
}

model Provider {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  title     String
  specialty String
  createdAt DateTime @default(now())

  patients      Patient[]
  appointments  Appointment[]
  clinicalNotes ClinicalNote[]
}

model Appointment {
  id         String   @id @default(cuid())
  patientId  String
  providerId String
  date       String
  time       String
  duration   Int
  type       String
  status     String   @default("scheduled")
  notes      String?
  createdAt  DateTime @default(now())

  patient       Patient          @relation(fields: [patientId], references: [id])
  provider      Provider         @relation(fields: [providerId], references: [id])
  clinicalNotes ClinicalNote[]
  claims        InsuranceClaim[]
}

model ClinicalNote {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String
  providerId    String
  date          String
  transcript    String?
  subjective    String
  objective     String
  assessment    String
  plan          String
  status        String   @default("draft")
  procedureCode String?
  toothNumbers  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient     @relation(fields: [patientId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  provider    Provider    @relation(fields: [providerId], references: [id])
}

model InsurancePlan {
  id                 String   @id @default(cuid())
  patientId          String
  provider           String
  memberId           String
  groupNumber        String
  deductible         Float
  deductibleMet      Float    @default(0)
  annualMax          Float
  annualUsed         Float    @default(0)
  verificationStatus String   @default("pending")
  verifiedDate       String?
  coPayPreventive    Float    @default(0)
  coPayBasic         Float    @default(20)
  coPayMajor         Float    @default(50)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient Patient          @relation(fields: [patientId], references: [id])
  claims  InsuranceClaim[]
}

model InsuranceClaim {
  id              String   @id @default(cuid())
  patientId       String
  insurancePlanId String
  appointmentId   String
  claimDate       String
  procedureCodes  String
  totalAmount     Float
  narrative       String
  status          String   @default("draft")
  submittedDate   String?
  approvedAmount  Float?
  denialReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  insurancePlan InsurancePlan @relation(fields: [insurancePlanId], references: [id])
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
}

model Balance {
  id                String   @id @default(cuid())
  patientId         String
  amount            Float
  dueDate           String
  lastPaymentDate   String?
  lastPaymentAmount Float?
  statementSent     Boolean  @default(false)
  statementDate     String?
  collectionStatus  String   @default("current")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
}

model RecallTask {
  id               String   @id @default(cuid())
  patientId        String
  lastHygieneDate  String
  recallDueDate    String
  daysOverdue      Int      @default(0)
  contactAttempts  Int      @default(0)
  lastContactDate  String?
  status           String   @default("pending")
  suggestedMessage String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
}

model RadiographStudy {
  id            String   @id @default(cuid())
  patientId     String
  date          String
  type          String
  findings      String
  reviewedBy    String?
  reviewedDate  String?
  providerNotes String?
  imageUrl      String
  createdAt     DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  description String
  userId      String   @default("demo-user")
  timestamp   DateTime @default(now())
  metadata    String?
}
